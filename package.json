{
  "name": "files",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "watcher": "bun run ./apps/watcher/src/index.ts",
    "worker": "bun run ./apps/worker/src/index.ts",
    "worker:scratch": "bun run ./apps/worker/src/scratch.ts",
    "db:push": "bunx drizzle-kit push",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}